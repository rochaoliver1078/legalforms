# ===========================================
# LEGALFORMS — Variáveis de Ambiente
# Configure estas variáveis na Vercel ou no .env.local
# ===========================================

# SUPABASE (obrigatório)
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui

# RESEND — Para envio de e-mails de notificação (opcional)
RESEND_API_KEY=re_sua-chave-resend-aqui

# URL DO APP — Em produção, use o domínio da Vercel
NEXT_PUBLIC_APP_URL=https://seu-app.vercel.app
